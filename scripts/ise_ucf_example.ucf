INST "mychip_top_XPCI_WRAP"                                         TNM = FFS:CORE_FFS    ;
#INST "mychip_top_XPCI_USER"                                         TNM = FFS:USER_FFS    ;
#
################################################################################
# Time Groups
################################################################################
#
TIMEGRP "ALL_FFS" = "CORE_FFS" : "USER_FFS" ;
TIMEGRP "ALL_BUS" = "BUS_PADS_D" : "BUS_PADS_C" : "BUS_PADS_G" ;
TIMEGRP "TRI_BUS" = "BUS_PADS_D" : "BUS_PADS_C" ;
TIMEGRP "PTP_BUS" = "BUS_PADS_G" ;
#
################################################################################
# Time Specs for PCIX Mode, 133 MHz, in a -7 Device
################################################################################
#
# Define Device, Package, And Speed Grade
#
#
# The following timespec is for the period.
#
INST "mychip_top_XPCI_WRAP/XPCI_DLL" CLKOUT_PHASE_SHIFT = FIXED ;
INST "mychip_top_XPCI_WRAP/XPCI_DLL" PHASE_SHIFT = +8 ;
NET "mychip_top_XPCI_WRAP/CLK_I" PERIOD =  7.50 ;
#
# The following timespec is for clock to out.
#
TIMEGRP "ALL_BUS" OFFSET = OUT  3.80 AFTER  "mychip_top_XPCI_WRAP/CLK_I" TIMEGRP "ALL_FFS";
#
# The following timespec is for setup.
#
TIMEGRP "ALL_BUS" OFFSET = IN   1.39 BEFORE "mychip_top_XPCI_WRAP/CLK_I" TIMEGRP "ALL_FFS";
#
################################################################################
# Time Specs for PCIX Mode, 100 MHz, in a -6 Device
################################################################################
#
#
# The following timespec is for the period.
#
