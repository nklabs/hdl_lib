## The following timespec is for clock to out.
##
##IMEGRP "ALL_BUS" OFFSET = OUT  3.80 AFTER  "mychip_top_XPCI_WRAP/CLK_I" TIMEGRP "ALL_FFS";
##
## The following timespec is for setup.
##
##IMEGRP "ALL_BUS" OFFSET = IN   1.20 BEFORE "mychip_top_XPCI_WRAP/CLK_I" TIMEGRP "ALL_FFS";
#
